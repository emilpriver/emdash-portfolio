---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

// Group posts by year
const postsByYear = sortedPosts.reduce((acc, post) => {
	const year = post.data.publishedAt?.getFullYear()?.toString() ?? "Unknown";
	if (!acc[year]) {
		acc[year] = [];
	}
	acc[year].push(post);
	return acc;
}, {} as Record<string, typeof sortedPosts>);

// Sort years descending
const years = Object.keys(postsByYear).sort((a, b) => parseInt(b) - parseInt(a));

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
	});
}

function getReadingTime(content: unknown) {
	if (!content || !Array.isArray(content)) return 0;
	const text = content.map((block: unknown) => {
		if (typeof block === "object" && block !== null && "children" in block) {
			const b = block as { children?: Array<{ text?: string }> };
			return b.children?.map((c) => c.text).join("") ?? "";
		}
		return "";
	}).join(" ");
	const words = text.split(/\s+/).filter(Boolean).length;
	return Math.ceil(words / 200);
}
---

<Base title="Emil Privér" description="Thoughts on building products, programming, and technology.">
	<div class="home-content">
		<header class="home-header">
			<h1 class="home-title">Emil Priv&eacute;r</h1>
			<p class="home-bio">
				Hey, I'm Emil Priv&eacute;r. I'm currently working as a Tech Lead and part-owner at Enad. I love everything about building products — from idea to shipping. I enjoy exploring new technologies and sharing what I learn along the way.
			</p>
		</header>

		<div class="posts-list">
			{years.map((year) => (
				<section class="year-section">
					<h2 class="year-header">
						{year}&nbsp;&nbsp;{postsByYear[year].length}
					</h2>
					<ul class="year-posts">
						{postsByYear[year].map((post) => (
							<li class="post-item">
								<span class="post-date">
									{formatDate(post.data.publishedAt)}
								</span>
								<a href={`/posts/${post.id}`} class="post-title">
									{post.data.title}
								</a>
								<span class="post-meta">
									{getReadingTime(post.data.content)} min
								</span>
							</li>
						))}
					</ul>
				</section>
			))}
		</div>
	</div>
</Base>

<style>
	.home-content {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.home-header {
		margin-bottom: var(--spacing-16);
	}

	.home-title {
		font-size: var(--font-size-4xl);
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-6);
	}

	.home-bio {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-12);
	}

	.year-section {
	}

	.year-header {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
		padding-bottom: var(--spacing-2);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.year-posts {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.post-item {
		display: flex;
		align-items: baseline;
		gap: var(--spacing-4);
		padding: var(--spacing-3) 0;
	}

	.post-date {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		min-width: 60px;
		flex-shrink: 0;
	}

	.post-title {
		font-size: var(--font-size-base);
		color: var(--color-text);
		text-decoration: none;
		flex: 1;
		transition: color var(--transition-fast);
	}

	.post-title:hover {
		color: var(--color-accent);
	}

	.post-meta {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		flex-shrink: 0;
	}

	@media (max-width: 640px) {
		.home-content {
			padding: var(--spacing-8) var(--spacing-4);
		}

		.home-title {
			font-size: var(--font-size-3xl);
		}

		.post-item {
			flex-wrap: wrap;
			gap: var(--spacing-2);
		}

		.post-date {
			min-width: auto;
		}

		.post-meta {
			width: 100%;
			padding-left: calc(60px + var(--spacing-4));
		}
	}
</style>
